# ==================== AetherPOS Webmaster - Vercel + Neon ====================
# Copy this file to .env.local and fill in your values

# Neon PostgreSQL connection string
# Get this from your Neon dashboard: https://console.neon.tech
# Use the POOLER connection string (not the direct one) for serverless
# Example: postgresql://user:pass@ep-cool-name-123456.us-east-2.pooler.neon.tech/aetherpos?sslmode=require
DATABASE_URL="postgresql://user:pass@ep-xxx.pooler.neon.tech/dbname?sslmode=require"

# Optional: if you need a non-pooling direct URL for migrations
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.neon.tech/dbname?sslmode=require"
