# ==================== AETHERPOS COMMAND CENTER ====================
# Production environment variables for Vercel + Neon deployment

# Neon PostgreSQL connection string (pooled — used by Prisma Client in serverless)
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/aetherpos?sslmode=require&pgbouncer=true"

# Neon PostgreSQL direct connection (used by Prisma CLI for migrations)
DIRECT_URL="postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/aetherpos?sslmode=require"

# NextAuth (optional — if you enable authentication)
# NEXTAUTH_URL="https://your-domain.vercel.app"
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
