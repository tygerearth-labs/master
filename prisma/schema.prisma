generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  price       Float
  durationDays Int
  maxOutlets  Int
  maxCrew     Int
  features    String   // JSON string of features array
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Owner {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String   // hashed password (simulated)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches     Branch[]
  subscriptions Subscription[]
  transactions Transaction[]
}

model Branch {
  id       String @id @default(cuid())
  name     String
  address  String?
  phone    String?
  ownerId  String
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   Owner    @relation(fields: [ownerId], references: [id])
  outlets Outlet[]
}

model Outlet {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  branchId  String
  status    String   @default("active") // active, inactive, suspended
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id])
  crew        Crew[]
  transactions Transaction[]
}

model Crew {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  role      String   @default("staff") // staff, manager, admin
  password  String   // hashed password (simulated)
  outletId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  outletId    String
  ownerId     String
  invoiceNo   String
  items       Int
  total       Float
  paymentMethod String @default("cash") // cash, qris, transfer, card
  status      String   @default("completed") // completed, void, refund
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id])
  owner  Owner  @relation(fields: [ownerId], references: [id])
}

model Subscription {
  id            String   @id @default(cuid())
  ownerId       String
  planId        String
  startDate     DateTime @default(now())
  endDate       DateTime
  status        String   @default("active") // active, expired, cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner Owner @relation(fields: [ownerId], references: [id])
  plan  Plan  @relation(fields: [planId], references: [id])
}