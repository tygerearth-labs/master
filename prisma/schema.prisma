// ==================== AETHERPOS COMMAND CENTER — PRISMA SCHEMA ====================
// Production schema for PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== PLAN (Editable Pricing) ====================
model Plan {
  id          String   @id @default(cuid())
  name        String                        // "Free", "Pro", "Enterprise"
  slug        String   @unique              // "free", "pro", "enterprise"
  price       Float    @default(0)          // Monthly price in IDR
  duration    Int      @default(30)         // Duration in days
  paymentLink String?                       // Payment URL
  features    String   @default("{}")       // JSON string of feature limits
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== OUTLET GROUP (Multi-Outlet) ====================
model OutletGroup {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User       @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  outlets   Outlet[]
}

// ==================== OUTLET ====================
model Outlet {
  id            String    @id @default(cuid())
  name          String
  address       String?
  phone         String?
  accountType   String    @default("free")
  isMain        Boolean   @default(false)
  groupId       String?
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  group         OutletGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  users         User[]
}

// ==================== USER ====================
model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  role      String   @default("CREW")
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet       Outlet       @relation(fields: [outletId], references: [id], onDelete: Cascade)
  ownedGroup   OutletGroup? @relation("GroupOwner")

  @@unique([email, outletId])
}

// ==================== AUDIT LOG ====================
model AuditLog {
  id          String   @id @default(cuid())
  action      String
  targetId    String
  targetType  String
  details     String?
  performedBy String   @default("webmaster")
  createdAt   DateTime @default(now())
}
