// ==================== AETHER POS SCHEMA — Neon PostgreSQL ====================
// Mirrors AetherPOS repo exactly. DO NOT modify field names/types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OutletGroup {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User            @relation("GroupOwner", fields: [ownerId], references: [id])
  outlets   Outlet[]
  transfers OutletTransfer[]
}

model Outlet {
  id            String    @id @default(cuid())
  name          String
  address       String?
  phone         String?
  accountType   String    @default("free")
  isMain        Boolean   @default(false)
  groupId       String?
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  group           OutletGroup?       @relation(fields: [groupId], references: [id])
  users           User[]
  products        Product[]
  customers       Customer[]
  categories      Category[]
  transactions    Transaction[]
  auditLogs       AuditLog[]
  setting         OutletSetting?
  promos          Promo[]
  crewPermissions CrewPermission[]
  productVariants ProductVariant[]
  transferItems   TransferItem[]
  transfersFrom   OutletTransfer[]     @relation("TransferFrom")
  transfersTo     OutletTransfer[]     @relation("TransferTo")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  password  String
  role      String   @default("CREW")
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  outlet              Outlet             @relation(fields: [outletId], references: [id])
  transactions        Transaction[]
  auditLogs           AuditLog[]
  crewPermission      CrewPermission?
  ownedGroup          OutletGroup?      @relation("GroupOwner")
  transfersCreated    OutletTransfer[]  @relation("TransferCreator")
  transfersReceived   OutletTransfer[]  @relation("TransferReceiver")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("zinc")
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  outlet   Outlet     @relation(fields: [outletId], references: [id])
  products Product[]
  promos   Promo[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String?
  barcode       String?
  hpp           Float    @default(0)
  price         Float
  bruto         Float    @default(0)
  netto         Float    @default(0)
  stock         Int      @default(0)
  lowStockAlert Int      @default(10)
  unit          String   @default("pcs")
  image         String?
  categoryId    String?
  outletId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  hasVariants    Boolean  @default(false)
  outlet           Outlet           @relation(fields: [outletId], references: [id])
  category         Category?        @relation(fields: [categoryId], references: [id])
  transactionItems TransactionItem[]
  variants         ProductVariant[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String?
  barcode   String?
  hpp       Float    @default(0)
  price     Float
  stock     Int      @default(0)
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet           Outlet            @relation(fields: [outletId], references: [id])
  transactionItems TransactionItem[]
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  whatsapp   String
  totalSpend Float    @default(0)
  points     Int      @default(0)
  outletId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  outlet       Outlet       @relation(fields: [outletId], references: [id])
  transactions Transaction[]
  loyaltyLogs  LoyaltyLog[]
}

model Transaction {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  subtotal      Float
  discount      Float    @default(0)
  pointsUsed    Int      @default(0)
  taxAmount     Float    @default(0)
  total         Float
  paymentMethod String
  paidAmount    Float    @default(0)
  change        Float    @default(0)
  note          String?
  outletId      String
  customerId    String?
  userId        String
  createdAt     DateTime @default(now())
  outlet       Outlet             @relation(fields: [outletId], references: [id])
  customer     Customer?          @relation(fields: [customerId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  items        TransactionItem[]
  loyaltyLogs  LoyaltyLog[]
}

model TransactionItem {
  id             String  @id @default(cuid())
  productId      String?
  variantId      String?
  productName    String
  variantName    String?
  price          Float
  qty            Int
  subtotal       Float
  itemDiscount   Float   @default(0)
  hpp            Float
  transactionId  String
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model LoyaltyLog {
  id            String    @id @default(cuid())
  type          String
  points        Int
  description   String
  customerId    String
  transactionId String?
  createdAt     DateTime @default(now())
  customer    Customer    @relation(fields: [customerId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  details    String?
  outletId   String
  userId     String
  createdAt  DateTime @default(now())
  outlet Outlet @relation(fields: [outletId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model OutletSetting {
  id      String @id @default(cuid())
  outletId String @unique
  paymentMethods String @default("CASH,QRIS")
  loyaltyEnabled         Boolean @default(true)
  loyaltyPointsPerAmount Int     @default(10000)
  loyaltyPointValue      Int     @default(100)
  receiptBusinessName String @default("Aether POS")
  receiptAddress      String @default("")
  receiptPhone        String @default("")
  receiptFooter       String @default("Terima kasih atas kunjungan Anda!")
  receiptLogo         String @default("")
  ppnEnabled  Boolean @default(false)
  ppnRate     Float   @default(11)
  manualDiscountEnabled Boolean @default(false)
  receiptDoublePrintEnabled Boolean @default(false)
  receiptMerchantCopyEnabled Boolean @default(true)
  receiptCustomerCopyEnabled Boolean @default(true)
  receiptBatchOrderEnabled  Boolean @default(false)
  themePrimaryColor String @default("emerald")
  telegramBotToken    String?
  telegramChatId      String?
  notifyOnTransaction Boolean @default(true)
  notifyOnCustomer    Boolean @default(true)
  notifyDailyReport   Boolean @default(true)
  notifyWeeklyReport  Boolean @default(false)
  notifyMonthlyReport Boolean @default(true)
  notifyOnInsight     Boolean @default(true)
  outlet     Outlet   @relation(fields: [outletId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Promo {
  id          String   @id @default(cuid())
  name        String
  type        String
  value       Float
  minPurchase Float?
  maxDiscount Float?
  active      Boolean  @default(true)
  outletId    String
  buyMinQty   Int      @default(0)
  discountType String  @default("PERCENTAGE")
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  outlet   Outlet   @relation(fields: [outletId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model CrewPermission {
  id       String @id @default(cuid())
  userId   String @unique
  pages    String @default("pos")
  outletId String
  user      User   @relation(fields: [userId], references: [id])
  outlet    Outlet @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Float    @default(0)
  duration    Int      @default(1)
  paymentLink String?
  features    String   @default("{}")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutletTransfer {
  id             String    @id @default(cuid())
  transferNumber String    @unique
  fromOutletId   String
  toOutletId     String
  status         String    @default("DRAFT")
  notes          String?
  receivedById   String?
  receivedAt     DateTime?
  createdById    String
  outletId       String
  groupId        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  fromOutlet Outlet            @relation("TransferFrom", fields: [fromOutletId], references: [id])
  toOutlet   Outlet            @relation("TransferTo", fields: [toOutletId], references: [id])
  group      OutletGroup?      @relation(fields: [groupId], references: [id])
  createdBy  User              @relation("TransferCreator", fields: [createdById], references: [id])
  receivedBy User?             @relation("TransferReceiver", fields: [receivedById], references: [id])
  items      TransferItem[]
}

model TransferItem {
  id              String   @id @default(cuid())
  transferId      String
  productName     String
  productSku      String?
  productBarcode  String?
  quantity        Int
  hpp             Float    @default(0)
  price           Float
  productSnapshot String?
  outletId        String
  createdAt       DateTime @default(now())
  transfer OutletTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  outlet   Outlet          @relation(fields: [outletId], references: [id])
}
